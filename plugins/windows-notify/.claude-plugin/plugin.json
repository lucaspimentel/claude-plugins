{
  "name": "windows-notify",
  "description": "Shows Windows toast notifications when Claude Code needs attention",
  "author": { "name": "Lucas Pimentel" },
  "repository": "https://github.com/lucaspimentel/claude-plugins",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/bin/WindowsNotify.exe"
          }
        ]
      }
    ]
  }
}
